@page "/work-orders"
@attribute [Authorize(Roles = "Admin,Office")]
@using CodeBlue.Field.App.Models
@using CodeBlue.Field.App.Services
@inject IFieldDataService FieldData

<PageTitle>Work Orders</PageTitle>

<section class="section-block dashboard-header-block">
    <div class="section-heading dashboard-header-row">
        <div class="dashboard-header-copy">
            <p class="eyebrow dashboard-eyebrow">Work Orders</p>
        </div>
    </div>
</section>

@if (_workOrders is null)
{
    <p>Loading work orders...</p>
}
else
{
    <section class="section-block">
        <div class="claim-toggle-row">
            <button class="@ToggleClass(_showActiveWorkOrders)" type="button" @onclick="() => _showActiveWorkOrders = true">Active</button>
            <button class="@ToggleClass(!_showActiveWorkOrders)" type="button" @onclick="() => _showActiveWorkOrders = false">History</button>
        </div>

        <div class="toolbar-row">
            <label class="search-box search-box-full">
                <span>Search</span>
                <input @bind="_search" @bind:event="oninput" placeholder="Search address, details, phone, or date" />
            </label>
        </div>

        <div class="data-list zebra-list">
            @if (VisibleWorkOrders.Count == 0)
            {
                <article class="empty-card">
                    <h3>No work orders in this view</h3>
                    <p>The current snapshot does not contain work orders matching the selected search and view.</p>
                </article>
            }
            else
            {
                @foreach (var workOrder in VisibleWorkOrders)
                {
                    <a class="data-card data-card-link @(IsHistoricStatus(workOrder.Status) ? "data-card-muted" : string.Empty)" href="@WorkOrderRoute(workOrder)">
                        <div class="history-card-main">
                            <div class="address-title">@StreetOnly(workOrder)</div>
                            <div class="card-subline card-subline-clamp card-subline-single">@ProblemText(workOrder)</div>
                        </div>
                    </a>
                }
            }
        </div>
    </section>
}

@code {
    private IReadOnlyList<WorkOrderSummary>? _workOrders;
    private string _search = string.Empty;
    private bool _showActiveWorkOrders = true;

    private IReadOnlyList<WorkOrderSummary> FilteredWorkOrders =>
        (_workOrders ?? [])
            .Where(MatchesSearch)
            .OrderByDescending(x => x.CompletedOn ?? x.ScheduledDate ?? x.DateSubmitted)
            .ThenBy(x => StreetOnly(x))
            .ToList();

    private IReadOnlyList<WorkOrderSummary> VisibleWorkOrders =>
        FilteredWorkOrders
            .Where(x => _showActiveWorkOrders ? !IsHistoricStatus(x.Status) : IsHistoricStatus(x.Status))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _workOrders = await FieldData.GetWorkOrdersAsync();
    }

    private bool MatchesSearch(WorkOrderSummary workOrder)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        var query = _search.Trim();
        return Contains(workOrder.Address, query)
            || Contains(workOrder.Street1, query)
            || Contains(workOrder.CustomerName, query)
            || Contains(workOrder.ServiceDetails, query)
            || Contains(workOrder.ServiceContactPhone, query)
            || Contains(workOrder.WorkOrderNumber, query)
            || DisplayDate(workOrder.CompletedOn ?? workOrder.ScheduledDate).Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private static bool Contains(string value, string query) =>
        !string.IsNullOrWhiteSpace(value) && value.Contains(query, StringComparison.OrdinalIgnoreCase);

    private static bool IsHistoricStatus(string status) =>
        status.Equals("Completed", StringComparison.OrdinalIgnoreCase)
        || status.Equals("Cancelled", StringComparison.OrdinalIgnoreCase);

    private static string StreetOnly(WorkOrderSummary workOrder) =>
        !string.IsNullOrWhiteSpace(workOrder.Street1)
            ? workOrder.Street1
            : FirstLine(string.IsNullOrWhiteSpace(workOrder.Address) ? workOrder.CustomerName : workOrder.Address);

    private static string ProblemText(WorkOrderSummary workOrder) =>
        string.IsNullOrWhiteSpace(workOrder.ServiceDetails) ? "No service details recorded." : workOrder.ServiceDetails;

    private static string DisplayDate(DateOnly? date) => date?.ToString("MM/dd/yyyy") ?? "—";
    private static string WorkOrderRoute(WorkOrderSummary workOrder) => IsHistoricStatus(workOrder.Status) ? $"/work-orders/history/{workOrder.Id}" : $"/work-orders/active/{workOrder.Id}";
    private string ToggleClass(bool active) => active ? "claim-toggle active" : "claim-toggle";
    private static string FirstLine(string value) =>
        string.IsNullOrWhiteSpace(value)
            ? "Unknown Address"
            : value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? value;

}
