@page "/service-requests"
@attribute [Authorize(Roles = "Admin,Office")]
@using CodeBlue.Field.App.Models
@using CodeBlue.Field.App.Services
@inject IFieldDataService FieldData

<PageTitle>Service Requests</PageTitle>

<section class="section-block dashboard-header-block">
    <div class="section-heading dashboard-header-row">
        <div class="dashboard-header-copy">
            <p class="eyebrow dashboard-eyebrow">Service Requests</p>
        </div>
    </div>
</section>

@if (_serviceRequests is null)
{
    <p>Loading service requests...</p>
}
else
{
    <section class="section-block">
        <div class="claim-toggle-row">
            <button class="@ToggleClass(_showCurrent)" type="button" @onclick="() => _showCurrent = true">Current</button>
            <button class="@ToggleClass(!_showCurrent)" type="button" @onclick="() => _showCurrent = false">History</button>
        </div>

        <div class="toolbar-row">
            <label class="search-box search-box-full">
                <input @bind="_search" @bind:event="oninput" placeholder="Search address, details, request #, contact, or builder" />
            </label>
        </div>

        <div class="data-list zebra-list">
            @if (VisibleRequests.Count == 0)
            {
                <article class="empty-card">
                    <h3>No service requests in this view</h3>
                    <p>The current snapshot does not contain service requests matching this view and search.</p>
                </article>
            }
            else
            {
                @foreach (var request in VisibleRequests)
                {
                    <a class="data-card data-card-link @(IsHistoricStatus(request.Status) ? "data-card-muted" : string.Empty)" href="@($"/service-requests/{request.Id}")">
                        <div class="history-card-row request-card-shell">
                            <div class="history-card-main">
                                <div class="address-title">@StreetOnly(request)</div>
                                <div class="card-subline card-subline-clamp">@ProblemText(request)</div>
                            </div>
                            <div class="card-meta-stack request-card-meta-stack">
                                <span>@request.Status</span>
                                @if (request.RouteGroup is int routeGroup)
                                {
                                    <span>Group @routeGroup</span>
                                }
                            </div>
                        </div>
                    </a>
                }
            }
        </div>
    </section>
}

@code {
    private IReadOnlyList<WorkOrderSummary>? _serviceRequests;
    private string _search = string.Empty;
    private bool _showCurrent = true;

    private IReadOnlyList<WorkOrderSummary> VisibleRequests =>
        (_serviceRequests ?? [])
            .Where(MatchesSearch)
            .Where(request => _showCurrent ? IsCurrentStatus(request.Status) : IsHistoricStatus(request.Status))
            .OrderByDescending(request => request.CompletedOn ?? request.DateSubmitted)
            .ThenBy(request => request.RouteGroup ?? int.MaxValue)
            .ThenBy(request => StreetOnly(request))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _serviceRequests = await FieldData.GetWorkOrdersAsync();
    }

    private bool MatchesSearch(WorkOrderSummary request)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        var query = _search.Trim();
        return Contains(request.Address, query)
            || Contains(request.Street1, query)
            || Contains(request.CustomerName, query)
            || Contains(request.ServiceDetails, query)
            || Contains(request.ServiceContactName, query)
            || Contains(request.ServiceContactPhone, query)
            || Contains(request.WorkOrderNumber, query)
            || Contains(request.BuilderCompanyName, query)
            || (request.RouteGroup?.ToString() ?? string.Empty).Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private static bool Contains(string value, string query) =>
        !string.IsNullOrWhiteSpace(value) && value.Contains(query, StringComparison.OrdinalIgnoreCase);

    private static bool IsCurrentStatus(string status) =>
        status.Equals("Pending", StringComparison.OrdinalIgnoreCase)
        || status.Equals("Active", StringComparison.OrdinalIgnoreCase);

    private static bool IsHistoricStatus(string status) =>
        status.Equals("Completed", StringComparison.OrdinalIgnoreCase);

    private static string StreetOnly(WorkOrderSummary request) =>
        !string.IsNullOrWhiteSpace(request.Street1)
            ? request.Street1
            : FirstLine(string.IsNullOrWhiteSpace(request.Address) ? request.CustomerName : request.Address);

    private static string ProblemText(WorkOrderSummary request) =>
        string.IsNullOrWhiteSpace(request.ServiceDetails) ? "No problem details recorded." : request.ServiceDetails;

    private string ToggleClass(bool active) => active ? "claim-toggle active" : "claim-toggle";

    private static string FirstLine(string value) =>
        string.IsNullOrWhiteSpace(value)
            ? "Unknown Address"
            : value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? value;
}
