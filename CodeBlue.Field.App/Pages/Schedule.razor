@page "/schedule"
@attribute [Authorize(Roles = "Admin,Office")]
@using CodeBlue.Field.App.Models
@using CodeBlue.Field.App.Services
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IFieldDataService FieldData
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Route Planning</PageTitle>

@if (!_hasLoaded)
{
    <p>Loading route planning...</p>
}
else
{
    <section class="sch-page">
        <section class="section-block sch-headerbar sch-header">
            <div class="sch-headerbar-inner sch-header-inner">
                <p class="eyebrow">Route Planning</p>
            </div>
        </section>

        <div class="sch-layout">
            <div class="sch-mobile-shell">
                <section class="section-block sch-map-card">
                    <div class="sch-map-header">
                        <div class="sch-radio-group" role="radiogroup" aria-label="Route planning mode">
                            <label class="sch-radio-option">
                                <input type="radio" name="route-mode-mobile" checked="@(_viewMode == "assign")" @onchange="(_) => SetAssignMode()" />
                                <span>Assign</span>
                            </label>
                            <label class="sch-radio-option">
                                <input type="radio" name="route-mode-mobile" checked="@(_viewMode == "route")" @onchange="(_) => SetRouteMode()" />
                                <span>Route</span>
                            </label>
                        </div>
                    </div>

                    <div id="cbScheduleMapMobile" class="sch-map"></div>
                </section>

                <section class="section-block sch-board-card">
                    @if (_viewMode == "assign")
                    {
                        <div class="sch-mobile-daybar">
                            @foreach (var group in RouteGroups)
                            {
                                <button class="@($"sch-daypill {GroupPillClass(group)} {(group == _selectedGroup ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectGroup(group)">
                                    Group @group
                                </button>
                            }
                        </div>

                        <div class="sch-mobile-minidrops">
                            @foreach (var group in RouteGroups)
                            {
                                <div class="sch-mini-slot">
                                    <div class="sch-mini-dropzone @(IsArmed ? "sch-dropzone-armed" : string.Empty)"
                                         @ondragover:preventDefault
                                         @ondrop="() => OnDropToGroupAsync(group)"
                                         @onclick="() => AssignArmedToGroupAsync(group)">
                                        <span class="sch-mini-date">Group @group</span>
                                        <strong class="sch-mini-count">@WorkForGroup(group).Count</strong>
                                    </div>
                                </div>
                            }
                        </div>

                        <div id="col-unscheduled-mobile" class="sch-mobile-tray" data-unscheduled-tray="true" @ondragover:preventDefault @ondrop="OnDropToUnassignedAsync">
                            <div class="sch-tray-head">
                                <strong class="sch-col-title">Unassigned</strong>
                                <span class="muted-note">Drag into a group</span>
                            </div>

                            <div class="data-list sch-dropzone">
                                @if (UnassignedRequests.Count == 0)
                                {
                                    <p class="muted-note">No unassigned service requests</p>
                                }
                                else
                                {
                                    @foreach (var request in UnassignedRequests)
                                    {
                                        @RenderScheduleCard(request)
                                    }
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="sch-route">
                            <div class="sch-route-tray">
                                <div class="sch-mobile-daybar">
                                    @foreach (var group in RouteGroups)
                                    {
                                        <button class="@($"sch-daypill {GroupPillClass(group)} {(group == _selectedGroup ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectGroup(group)">
                                            Group @group
                                        </button>
                                    }
                                </div>

                                <div class="sch-tray-head">
                                    <strong class="sch-col-title">Group @_selectedGroup Route</strong>
                                    <span class="section-tag">@SelectedGroupStops.Count</span>
                                    <span class="muted-note">Use arrows to reorder</span>
                                </div>

                                <div class="data-list">
                                    @if (SelectedGroupStops.Count == 0)
                                    {
                                        <p class="muted-note">No route stops in this group.</p>
                                    }
                                    else
                                    {
                                        @foreach (var request in SelectedGroupStops)
                                        {
                                            @RenderRouteCard(request)
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </section>
            </div>

            <div class="sch-desktop-split">
                <section class="section-block sch-map-card">
                    <div class="sch-map-header">
                        <div class="sch-radio-group" role="radiogroup" aria-label="Route planning mode">
                            <label class="sch-radio-option">
                                <input type="radio" name="route-mode-desktop" checked="@(_viewMode == "assign")" @onchange="(_) => SetAssignMode()" />
                                <span>Assign</span>
                            </label>
                            <label class="sch-radio-option">
                                <input type="radio" name="route-mode-desktop" checked="@(_viewMode == "route")" @onchange="(_) => SetRouteMode()" />
                                <span>Route</span>
                            </label>
                        </div>
                    </div>

                    <div id="cbScheduleMapDesktop" class="sch-map"></div>
                </section>

                <section class="section-block sch-board-card">
                    @if (_viewMode == "assign")
                    {
                        <div class="sch-board-desktop">
                            <div class="sch-columns">
                                @foreach (var group in RouteGroups)
                                {
                                    <div id="@($"col-group-{group}")" class="schedule-column sch-col @(group == _selectedGroup ? "sch-day-selected" : string.Empty)"
                                         @ondragover:preventDefault
                                         @ondrop="() => OnDropToGroupAsync(group)"
                                         @onclick="() => AssignArmedToGroupAsync(group)">
                                        <div class="sch-col-head">
                                            <strong class="sch-col-title">Group @group</strong>
                                            <span class="@($"sch-daypill {GroupPillClass(group)}")">@WorkForGroup(group).Count</span>
                                        </div>

                                        <div class="data-list">
                                            @foreach (var request in WorkForGroup(group))
                                            {
                                                @RenderScheduleCard(request)
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <div id="col-unscheduled" class="sch-mobile-tray" data-unscheduled-tray="true" @ondragover:preventDefault @ondrop="OnDropToUnassignedAsync">
                                <div class="sch-tray-head">
                                    <strong class="sch-col-title">Unassigned</strong>
                                    <span class="muted-note">Drag into a group</span>
                                </div>

                                <div class="data-list sch-dropzone">
                                    @if (UnassignedRequests.Count == 0)
                                    {
                                        <p class="muted-note">No unassigned service requests</p>
                                    }
                                    else
                                    {
                                        @foreach (var request in UnassignedRequests)
                                        {
                                            @RenderScheduleCard(request)
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="sch-route">
                            <div class="sch-route-tray">
                                <div class="sch-mobile-daybar">
                                    @foreach (var group in RouteGroups)
                                    {
                                        <button class="@($"sch-daypill {GroupPillClass(group)} {(group == _selectedGroup ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectGroup(group)">
                                            Group @group
                                        </button>
                                    }
                                </div>

                                <div class="sch-tray-head">
                                    <strong class="sch-col-title">Group @_selectedGroup Route</strong>
                                    <span class="section-tag">@SelectedGroupStops.Count</span>
                                    <span class="muted-note">Use arrows to reorder</span>
                                </div>

                                <div class="data-list">
                                    @if (SelectedGroupStops.Count == 0)
                                    {
                                        <p class="muted-note">No route stops in this group.</p>
                                    }
                                    else
                                    {
                                        @foreach (var request in SelectedGroupStops)
                                        {
                                            @RenderRouteCard(request)
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </section>
            </div>
        </div>
    </section>
}

@code {
    private static readonly IReadOnlyList<int> RouteGroups = [1, 2, 3, 4, 5];

    private readonly List<WorkOrderSummary> _allRequests = [];
    private readonly List<WorkOrderSummary> _unassigned = [];
    private readonly Dictionary<int, List<WorkOrderSummary>> _byGroup = [];
    private DotNetObjectReference<Schedule>? _dotNetRef;
    private bool _hasLoaded;
    private bool _scheduleAssetsReady;
    private string _viewMode = "assign";
    private int _selectedGroup = 1;
    private Guid? _dragWorkOrderId;
    private Guid? _armedWorkOrderId;
    private string? _lastMapRenderKey;
    private bool _preserveMapViewOnce;
    private bool _resetMapToDefaultOnce;

    private IReadOnlyList<WorkOrderSummary> UnassignedRequests => _unassigned;
    private IReadOnlyList<WorkOrderSummary> SelectedGroupStops =>
        _allRequests.Where(x => x.RouteGroup == _selectedGroup)
            .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
            .ThenBy(x => x.City)
            .ThenBy(x => StreetOnly(x))
            .ToList();
    private bool IsArmed => _armedWorkOrderId.HasValue;

    protected override async Task OnInitializedAsync() => await LoadWorkOrdersAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await EnsureScheduleAssetsAsync();
        _dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("cbScheduleMap.setDotNetRef", _dotNetRef);
        await RenderMapAsync();
    }

    public void Dispose() => _dotNetRef?.Dispose();

    private IReadOnlyList<WorkOrderSummary> WorkForGroup(int group) =>
        _byGroup.TryGetValue(group, out var list)
            ? list.OrderBy(x => x.ScheduledOrder ?? int.MaxValue).ThenBy(x => x.City).ThenBy(x => StreetOnly(x)).ToList()
            : [];

    private async Task LoadWorkOrdersAsync()
    {
        var requests = (await FieldData.GetWorkOrdersAsync())
            .Where(IsRoutePlanningStatus)
            .ToList();

        _allRequests.Clear();
        _allRequests.AddRange(requests);

        _unassigned.Clear();
        _unassigned.AddRange(requests.Where(x => x.RouteGroup is null).OrderBy(x => x.City).ThenBy(x => StreetOnly(x)));

        _byGroup.Clear();
        foreach (var group in RouteGroups)
        {
            _byGroup[group] = requests.Where(x => x.RouteGroup == group)
                .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
                .ThenBy(x => x.City)
                .ThenBy(x => StreetOnly(x))
                .ToList();
        }

        EnsureSelectedGroupIsPopulated();
        _hasLoaded = true;
        _lastMapRenderKey = null;
    }

    private void SelectGroup(int group)
    {
        _selectedGroup = group;
        _lastMapRenderKey = null;
    }

    private void SetAssignMode()
    {
        _viewMode = "assign";
        _preserveMapViewOnce = false;
        _resetMapToDefaultOnce = true;
        _lastMapRenderKey = null;
    }

    private void SetRouteMode()
    {
        _viewMode = "route";
        EnsureSelectedGroupIsPopulated();
        _preserveMapViewOnce = false;
        _resetMapToDefaultOnce = true;
        _lastMapRenderKey = null;
    }

    private void EnsureSelectedGroupIsPopulated()
    {
        if (SelectedGroupStops.Count > 0 || _allRequests.All(x => x.RouteGroup is null))
        {
            return;
        }

        var firstPopulatedGroup = RouteGroups.FirstOrDefault(group => _allRequests.Any(x => x.RouteGroup == group));
        if (firstPopulatedGroup != 0)
        {
            _selectedGroup = firstPopulatedGroup;
        }
    }

    private void BeginDrag(Guid id)
    {
        _dragWorkOrderId = id;
        _armedWorkOrderId = id;
    }

    private void Arm(Guid id) => _armedWorkOrderId = id;

    private async Task OnDropToGroupAsync(int group)
    {
        var id = _dragWorkOrderId ?? _armedWorkOrderId;
        if (!id.HasValue) return;

        _preserveMapViewOnce = true;
        ApplyLocalRouteGroupUpdate(id.Value, group);
        await FieldData.UpdateWorkOrderRouteGroupAsync(id.Value, group);
        await LoadWorkOrdersAsync();
        _dragWorkOrderId = null;
        _armedWorkOrderId = null;
    }

    private Task AssignArmedToGroupAsync(int group) =>
        _armedWorkOrderId.HasValue ? OnDropToGroupAsync(group) : Task.CompletedTask;

    private async Task OnDropToUnassignedAsync()
    {
        var id = _dragWorkOrderId ?? _armedWorkOrderId;
        if (!id.HasValue) return;

        _preserveMapViewOnce = true;
        ApplyLocalRouteGroupUpdate(id.Value, null);
        await FieldData.UpdateWorkOrderRouteGroupAsync(id.Value, null);
        await LoadWorkOrdersAsync();
        _dragWorkOrderId = null;
        _armedWorkOrderId = null;
    }

    private async Task MoveRouteStopAsync(Guid id, int direction)
    {
        _preserveMapViewOnce = false;
        _resetMapToDefaultOnce = true;
        await FieldData.ReorderRouteGroupAsync(id, direction);
        await LoadWorkOrdersAsync();
        _armedWorkOrderId = id;
    }

    private void ApplyLocalRouteGroupUpdate(Guid id, int? routeGroup)
    {
        var request = _allRequests.FirstOrDefault(x => x.Id == id);
        if (request is null) return;

        RemoveFromBoard(id);
        var nextOrder = routeGroup.HasValue
            ? WorkForGroup(routeGroup.Value).Select(x => x.ScheduledOrder ?? 0).DefaultIfEmpty(-1).Max() + 1
            : (int?)null;
        var updated = CloneWithRouteGroup(request, routeGroup, nextOrder);
        ReplaceMaster(updated);

        if (routeGroup is null)
        {
            _unassigned.Insert(0, updated);
        }
        else
        {
            _byGroup.TryAdd(routeGroup.Value, []);
            _byGroup[routeGroup.Value].Add(updated);
        }

        _lastMapRenderKey = null;
    }

    private async Task EnsureScheduleAssetsAsync()
    {
        if (_scheduleAssetsReady) return;
        await JS.InvokeVoidAsync("codeBlue.assets.ensureSchedule");
        _scheduleAssetsReady = true;
    }

    private async Task RenderMapAsync()
    {
        await EnsureScheduleAssetsAsync();

        IEnumerable<WorkOrderSummary> source = _viewMode == "route" ? SelectedGroupStops : _allRequests;
        var pins = source.Where(x => x.Latitude is not null && x.Longitude is not null)
            .Select((request, index) => new
            {
                id = request.Id,
                lat = request.Latitude,
                lng = request.Longitude,
                address = request.Address,
                label = StreetOnly(request),
                dayKey = request.RouteGroup.HasValue ? $"group:{request.RouteGroup.Value}" : "unscheduled",
                seq = _viewMode == "route" ? (int?)(index + 1) : null,
                badge = _viewMode == "route" ? (index + 1).ToString() : request.RouteGroup?.ToString(),
                serviceDescription = ProblemText(request),
                isUnscheduled = !request.RouteGroup.HasValue,
                routeDayBadge = request.RouteGroup?.ToString()
            })
            .ToList();

        var mapKey = $"{_viewMode}:{_selectedGroup}:{string.Join("|", pins.Select(p => $"{p.id}:{p.seq}:{p.badge}"))}";
        if (_lastMapRenderKey == mapKey) return;
        _lastMapRenderKey = mapKey;

        await JS.InvokeVoidAsync(
            "cbScheduleMap.renderPinsTo",
            "cbScheduleMap",
            pins,
            FieldMapDefaults.DefaultCenterLat,
            FieldMapDefaults.DefaultCenterLng,
            new
            {
                preserveView = _preserveMapViewOnce,
                forceDefaultView = _resetMapToDefaultOnce,
                defaultZoom = FieldMapDefaults.DefaultCenterZoom
            });
        await JS.InvokeVoidAsync("cbScheduleMap.invalidate");
        _preserveMapViewOnce = false;
        _resetMapToDefaultOnce = false;
    }

    [JSInvokable]
    public async Task OnMapPinRequested(string id)
    {
        if (!Guid.TryParse(id, out var requestId)) return;
        _preserveMapViewOnce = true;
        await FieldData.UpdateWorkOrderRouteGroupAsync(requestId, null);
        await LoadWorkOrdersAsync();
        _armedWorkOrderId = requestId;
        _dragWorkOrderId = null;

        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("ScheduleBoard.scrollToColumn", "unscheduled");
        await JS.InvokeVoidAsync("ScheduleBoard.scrollToWorkOrderInColumn", "unscheduled", requestId.ToString(), new { align = "top" });
        await JS.InvokeVoidAsync("ScheduleBoard.pulseWorkOrder", requestId.ToString());
    }

    [JSInvokable]
    public Task OnMapPinClicked(string id, bool isUnscheduled)
    {
        return HandleMapPinClickedAsync(id, isUnscheduled);
    }

    [JSInvokable]
    public Task OnMapPinArmed(string id)
    {
        if (!Guid.TryParse(id, out var requestId))
        {
            return Task.CompletedTask;
        }

        _armedWorkOrderId = requestId;
        _dragWorkOrderId = null;
        return Task.CompletedTask;
    }

    private async Task HandleMapPinClickedAsync(string id, bool isUnscheduled)
    {
        if (!isUnscheduled || !Guid.TryParse(id, out var requestId))
        {
            return;
        }

        _preserveMapViewOnce = true;

        var masterIndex = _allRequests.FindIndex(request => request.Id == requestId);
        if (masterIndex > 0)
        {
            var selected = _allRequests[masterIndex];
            _allRequests.RemoveAt(masterIndex);
            _allRequests.Insert(0, selected);
        }

        var unassignedIndex = _unassigned.FindIndex(request => request.Id == requestId);
        if (unassignedIndex > 0)
        {
            var selected = _unassigned[unassignedIndex];
            _unassigned.RemoveAt(unassignedIndex);
            _unassigned.Insert(0, selected);
        }

        _armedWorkOrderId = requestId;
        _dragWorkOrderId = null;

        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("ScheduleBoard.scrollToColumn", "unscheduled");
        await JS.InvokeVoidAsync("ScheduleBoard.scrollToWorkOrderInColumn", "unscheduled", requestId.ToString(), new { align = "top" });
        await JS.InvokeVoidAsync("ScheduleBoard.pulseWorkOrder", requestId.ToString());
    }

    private void RemoveFromBoard(Guid id)
    {
        _unassigned.RemoveAll(x => x.Id == id);
        foreach (var group in RouteGroups)
        {
            if (_byGroup.TryGetValue(group, out var list))
            {
                list.RemoveAll(x => x.Id == id);
            }
        }
    }

    private void ReplaceMaster(WorkOrderSummary updated)
    {
        var index = _allRequests.FindIndex(x => x.Id == updated.Id);
        if (index >= 0) _allRequests[index] = updated;
    }

    private static WorkOrderSummary CloneWithRouteGroup(WorkOrderSummary request, int? routeGroup, int? order) => new()
    {
        Id = request.Id,
        CustomerId = request.CustomerId,
        AssignedToUserId = request.AssignedToUserId,
        WorkOrderNumber = request.WorkOrderNumber,
        CustomerName = request.CustomerName,
        Address = request.Address,
        Street1 = request.Street1,
        City = request.City,
        Latitude = request.Latitude,
        Longitude = request.Longitude,
        Status = request.Status,
        Technician = request.Technician,
        GateCode = request.GateCode,
        AnimalsPresent = request.AnimalsPresent,
        ServiceDetails = request.ServiceDetails,
        DateSubmitted = request.DateSubmitted,
        RouteGroup = routeGroup,
        ScheduledDate = request.ScheduledDate,
        ScheduledOrder = order,
        ServiceStartupDate = request.ServiceStartupDate,
        ServiceContactName = request.ServiceContactName,
        ServiceContactPhone = request.ServiceContactPhone,
        BuilderCompanyName = request.BuilderCompanyName,
        BuilderContactName = request.BuilderContactName,
        BuilderContactPhone = request.BuilderContactPhone,
        BuilderEmail = request.BuilderEmail,
        CompletedBy = request.CompletedBy,
        CompletedOn = request.CompletedOn,
        HasPendingUpload = request.HasPendingUpload
    };

    private static bool IsRoutePlanningStatus(WorkOrderSummary request) =>
        request.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase)
        || request.Status.Equals("New", StringComparison.OrdinalIgnoreCase)
        || request.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);

    private static string GroupPillClass(int group) => group switch
    {
        1 => "cb-day-mon",
        2 => "cb-day-tue",
        3 => "cb-day-wed",
        4 => "cb-day-thu",
        5 => "cb-day-fri",
        _ => string.Empty
    };

    private static string StreetOnly(WorkOrderSummary request) =>
        !string.IsNullOrWhiteSpace(request.Street1) ? request.Street1 : FirstLine(string.IsNullOrWhiteSpace(request.Address) ? request.CustomerName : request.Address);

    private static string ProblemText(WorkOrderSummary request) =>
        string.IsNullOrWhiteSpace(request.ServiceDetails) ? "No service details recorded." : request.ServiceDetails;

    private static string DetailHref(WorkOrderSummary request) => $"/service-requests/{request.Id}";

    private static string SubmittedLabel(WorkOrderSummary request) => $"Submitted {request.DateSubmitted:M/d/yy}";

    private static string FirstLine(string value) =>
        string.IsNullOrWhiteSpace(value) ? "Unknown Address" : value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? value;

    private RenderFragment RenderScheduleCard(WorkOrderSummary request) => builder =>
    {
        builder.OpenElement(0, "article");
        builder.AddAttribute(1, "id", $"wo-{request.Id}");
        builder.AddAttribute(2, "class", $"sch-item schedule-stop-card {(request.Id == _armedWorkOrderId ? "sch-item-armed" : string.Empty)}");
        builder.AddAttribute(3, "role", "button");
        builder.AddAttribute(4, "tabindex", "0");
        builder.AddAttribute(5, "draggable", "true");
        builder.AddAttribute(6, "ondragstart", EventCallback.Factory.Create<DragEventArgs>(this, _ => BeginDrag(request.Id)));
        builder.AddAttribute(7, "onclick", EventCallback.Factory.Create(this, () => Arm(request.Id)));
        builder.OpenElement(8, "div");
        builder.AddAttribute(9, "class", "sch-item-row");

        builder.OpenElement(10, "div");
        builder.AddAttribute(11, "class", "sch-item-title");
        builder.OpenElement(12, "span");
        builder.AddAttribute(13, "class", "sch-item-street");
        builder.AddContent(14, StreetOnly(request));
        builder.CloseElement();
        builder.OpenElement(15, "span");
        builder.AddAttribute(16, "class", "sch-item-desc");
        builder.AddContent(17, ProblemText(request));
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(18, "div");
        builder.AddAttribute(19, "class", "sch-item-meta");
        builder.OpenElement(20, "a");
        builder.AddAttribute(21, "class", "icon-action ghost-action sch-item-open");
        builder.AddAttribute(22, "href", DetailHref(request));
        builder.AddAttribute(23, "title", "Open service request");
        builder.AddAttribute(24, "aria-label", "Open service request");
        builder.AddEventStopPropagationAttribute(25, "onclick", true);
        builder.OpenElement(26, "span");
        builder.AddAttribute(27, "class", "schedule-open-glyph");
        builder.AddContent(28, "↗");
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(29, "span");
        builder.AddAttribute(30, "class", "sch-item-date");
        builder.AddContent(31, SubmittedLabel(request));
        builder.CloseElement();
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RenderRouteCard(WorkOrderSummary request) => builder =>
    {
        var order = SelectedGroupStops.ToList().FindIndex(x => x.Id == request.Id);
        var isFirst = order <= 0;
        var isLast = order == SelectedGroupStops.Count - 1;
        builder.OpenElement(0, "article");
        builder.AddAttribute(1, "class", $"sch-item schedule-stop-card sch-route-card {(request.Id == _armedWorkOrderId ? "sch-item-armed" : string.Empty)}");
        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "class", "sch-route-card-main");

        builder.OpenElement(4, "div");
        builder.AddAttribute(5, "class", "sch-route-order");
        builder.AddContent(6, order + 1);
        builder.CloseElement();

        builder.OpenElement(7, "div");
        builder.AddAttribute(8, "class", "sch-route-copy");
        builder.OpenElement(9, "span");
        builder.AddAttribute(10, "class", "sch-item-street sch-route-street");
        builder.AddContent(11, StreetOnly(request));
        builder.CloseElement();
        builder.OpenElement(12, "span");
        builder.AddAttribute(13, "class", "sch-item-desc sch-route-desc");
        builder.AddContent(14, ProblemText(request));
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(15, "div");
        builder.AddAttribute(16, "class", "sch-route-actions");
        builder.AddAttribute(17, "style", "flex:0 0 1.6rem;width:1.6rem;display:flex;flex-direction:column;align-self:stretch;justify-content:stretch;background:transparent;");

        builder.OpenElement(18, "button");
        builder.AddAttribute(19, "class", "sch-route-shift sch-route-shift-up");
        builder.AddAttribute(20, "type", "button");
        builder.AddAttribute(21, "disabled", isFirst);
        builder.AddAttribute(22, "onclick", EventCallback.Factory.Create(this, () => MoveRouteStopAsync(request.Id, -1)));
