@page "/schedule"
@page "/schedule/{Date:datetime?}"
@attribute [Authorize(Roles = "Admin,Office")]
@using CodeBlue.Field.App.Models
@using CodeBlue.Field.App.Services
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IFieldDataService FieldData
@inject IJSRuntime JS

<PageTitle>Schedule</PageTitle>

@if (!_hasLoaded)
{
    <p>Loading schedule...</p>
}
else
{
    <section class="sch-page">
        <section class="section-block sch-headerbar sch-header">
            <div class="sch-headerbar-inner sch-header-inner">
                <p class="eyebrow">Scheduling</p>
            </div>
        </section>

        <div class="sch-layout">
            <div class="sch-top-row">
                <div class="sch-mobile-shell">
                    <section class="section-block sch-map-card">
                        <div class="sch-date-toolbar">
                            <button class="day-nav-button" type="button" @onclick="PrevWeek" aria-label="Previous week">
                                <svg class="nav-chevron-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M14.41 7.41 9.83 12l4.58 4.59L13 18l-6-6 6-6z"></path>
                                </svg>
                            </button>
                            <input class="compact-input sch-date-input" type="date" value="@_selectedDayString" @onchange="OnSelectedDateChanged" />
                            <button class="day-nav-button" type="button" @onclick="NextWeek" aria-label="Next week">
                                <svg class="nav-chevron-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="m10 6 6 6-6 6-1.41-1.41L13.17 12 8.59 7.41z"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="sch-map-header">
                            <div class="sch-radio-group" role="radiogroup" aria-label="Schedule view mode">
                                <label class="sch-radio-option">
                                    <input type="radio" name="schedule-mobile-mode" checked="@(_viewMode == "assign")" @onchange="(_) => SetAssignMode()" />
                                    <span>Assign</span>
                                </label>
                                <label class="sch-radio-option">
                                    <input type="radio" name="schedule-mobile-mode" checked="@(_viewMode == "route")" @onchange="(_) => SetRouteMode()" />
                                    <span>Route</span>
                                </label>
                            </div>
                            <span class="section-tag">Saved locally</span>
                        </div>

                        <div id="cbScheduleMapMobile" class="sch-map"></div>
                    </section>

                    <section class="section-block sch-board-card">
                        @if (_viewMode == "assign")
                        {
                            <div class="sch-mobile-daybar">
                                @foreach (var day in WeekDays)
                                {
                                    <button class="@($"sch-daypill {DayPillClass(day)} {(day == _selectedDay ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectDay(day)">
                                        @day.ToString("ddd")
                                    </button>
                                }
                            </div>

                            <div class="sch-mobile-minidrops">
                                @foreach (var day in WeekDays)
                                {
                                        <div class="sch-mini-slot">
                                            <div class="sch-mini-dropzone @(IsArmed ? "sch-dropzone-armed" : string.Empty)"
                                             @ondragover:preventDefault
                                             @ondragover="OnDragOver"
                                             @ondrop="() => OnDropToDayAsync(day)"
                                             @onclick="() => AssignArmedToDayAsync(day)">
                                                <span class="sch-mini-date">@day.ToString("M/d")</span>
                                                <strong class="sch-mini-count">@WorkForDay(day).Count</strong>
                                            </div>
                                        </div>
                                    }
                                </div>

                            <div class="sch-mobile-tray" data-unscheduled-tray="true">
                                <div class="sch-tray-head">
                                    <strong class="sch-col-title">Unscheduled</strong>
                                    <span class="muted-note">Drag into a day</span>
                                </div>

                                <div class="data-list sch-dropzone"
                                     @ondragover:preventDefault
                                     @ondragover="OnDragOver"
                                     @ondrop="OnDropToUnscheduledAsync">
                                    @if (PendingRequests.Count == 0)
                                    {
                                        <p class="muted-note">No unscheduled work orders</p>
                                    }
                                    else
                                    {
                                        @foreach (var request in PendingRequests)
                                        {
                                            @RenderScheduleCard(request)
                                        }
                                    }
                                </div>
                            </div>

                        }
                        else
                        {
                            <div class="sch-route">
                                <div class="sch-mobile-daybar">
                                    @foreach (var day in WeekDays)
                                    {
                                        <button class="@($"sch-daypill {DayPillClass(day)} {(day == _selectedDay ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectDay(day)">
                                            @day.ToString("ddd")
                                        </button>
                                    }
                                </div>

                                <div class="sch-mobile-tray sch-route-tray">
                                    <div class="sch-tray-head">
                                        <strong class="sch-col-title">@_selectedDay.ToString("ddd M/d") Route</strong>
                                        <span class="section-tag">@SelectedDayStops.Count</span>
                                        <span class="muted-note">Use arrows to reorder</span>
                                    </div>

                                    <div class="data-list">
                                        @if (SelectedDayStops.Count == 0)
                                        {
                                            <p class="muted-note">No route stops for this day.</p>
                                        }
                                        else
                                        {
                                            @foreach (var stop in SelectedDayStops)
                                            {
                                                @RenderScheduleRouteCard(stop)
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </section>
                </div>

                <div class="sch-desktop-split">
                    <section class="section-block sch-map-card">
                        <div class="sch-date-toolbar">
                            <button class="day-nav-button" type="button" @onclick="PrevWeek" aria-label="Previous week">
                                <svg class="nav-chevron-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M14.41 7.41 9.83 12l4.58 4.59L13 18l-6-6 6-6z"></path>
                                </svg>
                            </button>
                            <input class="compact-input sch-date-input" type="date" value="@_selectedDayString" @onchange="OnSelectedDateChanged" />
                            <button class="day-nav-button" type="button" @onclick="NextWeek" aria-label="Next week">
                                <svg class="nav-chevron-icon" viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="m10 6 6 6-6 6-1.41-1.41L13.17 12 8.59 7.41z"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="sch-map-header">
                            <div class="sch-radio-group" role="radiogroup" aria-label="Schedule view mode">
                                <label class="sch-radio-option">
                                    <input type="radio" name="schedule-desktop-mode" checked="@(_viewMode == "assign")" @onchange="(_) => SetAssignMode()" />
                                    <span>Assign</span>
                                </label>
                                <label class="sch-radio-option">
                                    <input type="radio" name="schedule-desktop-mode" checked="@(_viewMode == "route")" @onchange="(_) => SetRouteMode()" />
                                    <span>Route</span>
                                </label>
                            </div>

                            @if (_viewMode == "route")
                            {
                                <div class="sch-route-daystrip">
                                    @foreach (var day in WeekDays)
                                    {
                                        <button class="@($"sch-daypill {DayPillClass(day)} {(day == _selectedDay ? "is-active" : string.Empty)}")" type="button" @onclick="() => SelectDay(day)">
                                            @day.ToString("ddd M/d")
                                        </button>
                                    }
                                </div>
                            }

                            <span class="section-tag">Saved locally</span>
                        </div>

                        <div id="cbScheduleMapDesktop" class="sch-map"></div>
                    </section>

                    <section class="section-block sch-board-card">
                        @if (_viewMode == "assign")
                        {
                            <div class="sch-board-desktop">
                                <div class="sch-columns">
                                    @foreach (var day in WeekDays)
                                    {
                                        <div class="schedule-column sch-col @SelectedDayClass(day)"
                                             @ondragover:preventDefault
                                             @ondragover="OnDragOver"
                                             @ondrop="() => OnDropToDayAsync(day)"
                                             @onclick="() => AssignArmedToDayAsync(day)">
                                            <div class="sch-col-head">
                                                <strong class="sch-col-title">@day.ToString("ddd M/d")</strong>
                                                <span class="@($"sch-daypill {DayPillClass(day)}")">@WorkForDay(day).Count</span>
                                                <button class="icon-action ghost-action" type="button" @onclick="() => SelectDay(day)" aria-label="Select day">
                                                    <span class="material-symbols-rounded">my_location</span>
                                                </button>
                                            </div>

                                            <div class="data-list">
                                                @foreach (var stop in WorkForDay(day))
                                                {
                                                    @RenderScheduleCard(stop)
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="sch-mobile-tray"
                                     data-unscheduled-tray="true"
                                     @ondragover:preventDefault
                                     @ondragover="OnDragOver"
                                     @ondrop="OnDropToUnscheduledAsync">
                                    <div class="sch-tray-head">
                                        <strong class="sch-col-title">Unscheduled</strong>
                                        <span class="muted-note">Drag into a day</span>
                                    </div>

                                    <div class="data-list sch-dropzone">
                                        @if (PendingRequests.Count == 0)
                                        {
                                            <p class="muted-note">No unscheduled work orders</p>
                                        }
                                        else
                                        {
                                            @foreach (var request in PendingRequests)
                                            {
                                                @RenderScheduleCard(request)
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="sch-route">
                                <div class="sch-route-tray">
                                    <div class="sch-tray-head">
                                        <strong class="sch-col-title">@_selectedDay.ToString("ddd M/d") Route</strong>
                                        <span class="section-tag">@SelectedDayStops.Count</span>
                                        <span class="muted-note">Use arrows to reorder</span>
                                    </div>

                                    <div class="data-list">
                                        @if (SelectedDayStops.Count == 0)
                                        {
                                            <p class="muted-note">No route stops for this day.</p>
                                        }
                                        else
                                        {
                                            @foreach (var stop in SelectedDayStops)
                                            {
                                                @RenderScheduleRouteCard(stop)
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </section>
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public DateTime? Date { get; set; }

    private List<WorkOrderSummary> _dragItems = [];
    private List<WorkOrderSummary> _unscheduled = [];
    private Dictionary<DateOnly, List<WorkOrderSummary>> _byDay = [];
    private bool _hasLoaded;
    private DateOnly _selectedDay = DateOnly.FromDateTime(DateTime.Today);
    private string _viewMode = "assign";
    private string _mapFilter = "week";
    private string? _lastMapRenderKey;
    private bool _scheduleAssetsReady;
    private Guid? _dragWorkOrderId;
    private Guid? _armedWorkOrderId;
    private DotNetObjectReference<Schedule>? _dotNetRef;

    private const double DefaultCenterLat = 36.175052;
    private const double DefaultCenterLng = -115.156251;

    private string _selectedDayString => _selectedDay.ToString("yyyy-MM-dd");

    private IReadOnlyList<WorkOrderSummary> PendingRequests => _unscheduled;

    private IReadOnlyList<WorkOrderSummary> SelectedDayStops =>
        GetDayList(_selectedDay)
            .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
            .ThenBy(x => StreetOnly(x))
            .ToList();

    private IReadOnlyList<DateOnly> WeekDays
    {
        get
        {
            var baseDay = _selectedDay.ToDateTime(TimeOnly.MinValue);
            var mondayOffset = baseDay.DayOfWeek == DayOfWeek.Sunday ? -6 : 1 - (int)baseDay.DayOfWeek;
            var monday = _selectedDay.AddDays(mondayOffset);
            return Enumerable.Range(0, 5).Select(x => monday.AddDays(x)).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _selectedDay = Date.HasValue ? DateOnly.FromDateTime(Date.Value) : DateOnly.FromDateTime(DateTime.Today);
        await LoadWorkOrdersAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Date.HasValue)
        {
            _selectedDay = DateOnly.FromDateTime(Date.Value);
            _lastMapRenderKey = null;
        }

        await Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await EnsureScheduleAssetsAsync();

        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("cbScheduleMap.setDotNetRef", _dotNetRef);
        }

        await RenderMapAsync();

        if (firstRender)
        {
            await Task.Delay(150);
            _lastMapRenderKey = null;
            await RenderMapAsync();
        }
    }

    private IReadOnlyList<WorkOrderSummary> WorkForDay(DateOnly day) => GetDayList(day);

    private bool IsArmed => _armedWorkOrderId.HasValue;

    private void PrevWeek()
    {
        _selectedDay = _selectedDay.AddDays(-7);
        _lastMapRenderKey = null;
    }

    private void NextWeek()
    {
        _selectedDay = _selectedDay.AddDays(7);
        _lastMapRenderKey = null;
    }

    private void OnSelectedDateChanged(ChangeEventArgs args)
    {
        if (DateOnly.TryParse(args.Value?.ToString(), out var parsed))
        {
            _selectedDay = parsed;
            _lastMapRenderKey = null;
        }
    }

    private void SelectDay(DateOnly day)
    {
        _selectedDay = day;
        _mapFilter = _viewMode == "route" ? "selected" : "week";
        _lastMapRenderKey = null;
    }

    private void SetAssignMode()
    {
        _viewMode = "assign";
        _mapFilter = "week";
        _lastMapRenderKey = null;
    }

    private void SetRouteMode()
    {
        _viewMode = "route";
        _mapFilter = "selected";
        _lastMapRenderKey = null;
    }

    private void BeginDrag(Guid workOrderId)
    {
        _dragWorkOrderId = workOrderId;
        _armedWorkOrderId = workOrderId;
    }

    private void ArmWorkOrder(Guid workOrderId)
    {
        _armedWorkOrderId = workOrderId;
    }

    private void OnDragOver(DragEventArgs _)
    {
    }

    private async Task OnDropToDayAsync(DateOnly day)
    {
        var workOrderId = _dragWorkOrderId ?? _armedWorkOrderId;
        if (!workOrderId.HasValue)
        {
            return;
        }

        ApplyLocalScheduleUpdate(workOrderId.Value, day);
        await InvokeAsync(StateHasChanged);
        await FieldData.UpdateWorkOrderScheduleAsync(workOrderId.Value, day);
        await LoadWorkOrdersAsync();
        _dragWorkOrderId = null;
        _armedWorkOrderId = null;
    }

    private Task AssignArmedToDayAsync(DateOnly day)
        => _armedWorkOrderId.HasValue ? OnDropToDayAsync(day) : Task.CompletedTask;

    private async Task OnDropToUnscheduledAsync()
    {
        var workOrderId = _dragWorkOrderId ?? _armedWorkOrderId;
        if (!workOrderId.HasValue)
        {
            return;
        }

        ApplyLocalScheduleUpdate(workOrderId.Value, null);
        await InvokeAsync(StateHasChanged);
        await FieldData.UpdateWorkOrderScheduleAsync(workOrderId.Value, null);
        await LoadWorkOrdersAsync();
        _dragWorkOrderId = null;
        _armedWorkOrderId = null;
    }

    private async Task MoveRouteStopAsync(Guid workOrderId, int direction)
    {
        if (direction == 0)
        {
            return;
        }

        if (!_byDay.TryGetValue(_selectedDay, out var dayList))
        {
            return;
        }

        var orderedDay = dayList
            .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
            .ThenBy(x => StreetOnly(x))
            .ToList();

        var currentIndex = orderedDay.FindIndex(x => x.Id == workOrderId);
        if (currentIndex < 0)
        {
            return;
        }

        var destinationIndex = Math.Clamp(currentIndex + direction, 0, orderedDay.Count - 1);
        if (destinationIndex == currentIndex)
        {
            return;
        }

        var moving = orderedDay[currentIndex];
        orderedDay.RemoveAt(currentIndex);
        orderedDay.Insert(destinationIndex, moving);

        for (var i = 0; i < orderedDay.Count; i++)
        {
            orderedDay[i] = CloneWithSchedule(orderedDay[i], orderedDay[i].ScheduledDate, i);
            ReplaceInDragItems(orderedDay[i]);
        }

        _byDay[_selectedDay] = orderedDay;
        _armedWorkOrderId = workOrderId;
        _lastMapRenderKey = null;

        await InvokeAsync(StateHasChanged);
        await FieldData.ReorderScheduledWorkOrderAsync(workOrderId, direction);
        await LoadWorkOrdersAsync();
        _armedWorkOrderId = workOrderId;
    }

    private async Task LoadWorkOrdersAsync()
    {
        var list = (await FieldData.GetWorkOrdersAsync())
            .Where(IsSchedulableStatus)
            .ToList();

        _unscheduled = list
            .Where(x => x.ScheduledDate is null)
            .OrderBy(x => x.City)
            .ThenBy(x => StreetOnly(x))
            .ToList();

        _byDay.Clear();
        foreach (var day in WeekDays)
        {
            _byDay[day] = list
                .Where(x => x.ScheduledDate == day)
                .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
                .ThenBy(x => x.City)
                .ThenBy(x => StreetOnly(x))
                .ToList();
        }

        _dragItems = _unscheduled
            .Concat(WeekDays.SelectMany(GetDayList))
            .GroupBy(x => x.Id)
            .Select(x => x.First())
            .ToList();

        _hasLoaded = true;
        _lastMapRenderKey = null;
    }

    private void ApplyLocalScheduleUpdate(Guid workOrderId, DateOnly? scheduledDate)
    {
        var workOrder = _dragItems.FirstOrDefault(x => x.Id == workOrderId);
        if (workOrder is null)
        {
            return;
        }

        RemoveFromBoard(workOrderId);

        var nextOrder = scheduledDate is null
            ? (int?)null
            : GetDayList(scheduledDate.Value)
                .Select(x => x.ScheduledOrder ?? 0)
                .DefaultIfEmpty(-1)
                .Max() + 1;

        var updated = CloneWithSchedule(workOrder, scheduledDate, nextOrder);

        ReplaceInDragItems(updated);

        if (scheduledDate is null)
        {
            _unscheduled.Insert(0, updated);
        }
        else
        {
            if (!_byDay.TryGetValue(scheduledDate.Value, out var dayList))
            {
                dayList = [];
                _byDay[scheduledDate.Value] = dayList;
            }

            dayList.Add(updated);
            _byDay[scheduledDate.Value] = dayList
                .OrderBy(x => x.ScheduledOrder ?? int.MaxValue)
                .ThenBy(x => x.City)
                .ThenBy(x => StreetOnly(x))
                .ToList();
        }

        _lastMapRenderKey = null;
    }

    private async Task RenderMapAsync()
    {
        await EnsureScheduleAssetsAsync();

        IEnumerable<WorkOrderSummary> mapSource = _mapFilter switch
        {
            "selected" => SelectedDayStops,
            "unscheduled" => _unscheduled,
            _ => _dragItems
        };

        var orderedMapSource = _mapFilter == "selected"
            ? SelectedDayStops
            : mapSource.ToList();

        var pins = orderedMapSource
            .Where(x => x.Latitude is not null && x.Longitude is not null)
            .Select((stop, index) => new ScheduleMapPin(
                stop.Id,
                stop.Latitude,
                stop.Longitude,
                stop.Address,
                ProblemText(stop),
                stop.ScheduledDate.HasValue ? DayKey(stop.ScheduledDate.Value) : "unscheduled",
                _mapFilter == "selected" ? index + 1 : null,
                _mapFilter == "week" && stop.ScheduledDate.HasValue ? DayBadge(stop.ScheduledDate.Value) : null,
                ProblemText(stop),
                !stop.ScheduledDate.HasValue,
                _mapFilter == "selected" && stop.ScheduledDate.HasValue ? DayBadge(_selectedDay) : null))
            .ToList();

        var mapKey = $"{_viewMode}:{_selectedDay:yyyy-MM-dd}:{string.Join("|", pins.Select(p => $"{p.Id}:{p.Seq}:{p.Badge}:{p.Lat}:{p.Lng}"))}";
        if (_lastMapRenderKey == mapKey)
        {
            return;
        }

        _lastMapRenderKey = mapKey;

        var targetId = await JS.InvokeAsync<bool>("cbScheduleMap.isMobile")
            ? "cbScheduleMapMobile"
            : "cbScheduleMapDesktop";

        await JS.InvokeVoidAsync("cbScheduleMap.renderPinsTo", targetId, pins, DefaultCenterLat, DefaultCenterLng);
        await JS.InvokeVoidAsync("cbScheduleMap.invalidate");
    }

    private async Task EnsureScheduleAssetsAsync()
    {
        if (_scheduleAssetsReady)
        {
            return;
        }

        await JS.InvokeVoidAsync("codeBlue.assets.ensureSchedule");
        _scheduleAssetsReady = true;
    }

    [JSInvokable]
    public async Task OnMapPinClicked(string id, bool isUnscheduled)
    {
        if (!isUnscheduled || !Guid.TryParse(id, out var workOrderId))
        {
            return;
        }

        var masterIndex = _dragItems.FindIndex(x => x.Id == workOrderId);
        if (masterIndex > 0)
        {
            var selected = _dragItems[masterIndex];
            _dragItems.RemoveAt(masterIndex);
            _dragItems.Insert(0, selected);
        }

        var unscheduledIndex = _unscheduled.FindIndex(x => x.Id == workOrderId);
        if (unscheduledIndex > 0)
        {
            var selected = _unscheduled[unscheduledIndex];
            _unscheduled.RemoveAt(unscheduledIndex);
            _unscheduled.Insert(0, selected);
        }

        _armedWorkOrderId = workOrderId;
        _dragWorkOrderId = null;

        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("ScheduleBoard.scrollToColumn", "unscheduled");
        await JS.InvokeVoidAsync("ScheduleBoard.scrollToWorkOrderInColumn", "unscheduled", workOrderId.ToString(), new { align = "top" });
        await JS.InvokeVoidAsync("ScheduleBoard.pulseWorkOrder", workOrderId.ToString());
    }

    [JSInvokable]
    public async Task OnMapPinRequested(string id)
    {
        if (!Guid.TryParse(id, out var workOrderId))
        {
            return;
        }

        ApplyLocalScheduleUpdate(workOrderId, null);
        await InvokeAsync(StateHasChanged);
        await FieldData.UpdateWorkOrderScheduleAsync(workOrderId, null);
        _armedWorkOrderId = workOrderId;
        _dragWorkOrderId = null;
        await LoadWorkOrdersAsync();
        await InvokeAsync(StateHasChanged);
        _lastMapRenderKey = null;
    }

    private string SelectedDayClass(DateOnly day) => day == _selectedDay ? "sch-day-selected" : string.Empty;

    private List<WorkOrderSummary> GetDayList(DateOnly day) =>
        _byDay.TryGetValue(day, out var list) ? list : [];

    private static string DayKey(DateOnly day) => $"day:{day:yyyy-MM-dd}";

    private static string StreetOnly(WorkOrderSummary workOrder) =>
        !string.IsNullOrWhiteSpace(workOrder.Street1)
            ? workOrder.Street1
            : FirstLine(string.IsNullOrWhiteSpace(workOrder.Address) ? workOrder.CustomerName : workOrder.Address);

    private static string ProblemText(WorkOrderSummary workOrder) =>
        string.IsNullOrWhiteSpace(workOrder.ServiceDetails) ? "No service details recorded." : workOrder.ServiceDetails;

    private static bool IsSchedulableStatus(WorkOrderSummary workOrder) =>
        workOrder.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase)
        || workOrder.Status.Equals("New", StringComparison.OrdinalIgnoreCase)
        || workOrder.Status.Equals("Active", StringComparison.OrdinalIgnoreCase);

    private void RemoveFromBoard(Guid workOrderId)
    {
        _unscheduled.RemoveAll(x => x.Id == workOrderId);

        foreach (var day in WeekDays)
        {
            if (_byDay.TryGetValue(day, out var list))
            {
                list.RemoveAll(x => x.Id == workOrderId);
            }
        }
    }

    private void ReplaceInDragItems(WorkOrderSummary updated)
    {
        var existingIndex = _dragItems.FindIndex(x => x.Id == updated.Id);
        if (existingIndex >= 0)
        {
            _dragItems[existingIndex] = updated;
        }
        else
        {
            _dragItems.Add(updated);
        }
    }

    private static WorkOrderSummary CloneWithSchedule(WorkOrderSummary existing, DateOnly? scheduledDate, int? scheduledOrder) =>
        new()
        {
            Id = existing.Id,
            CustomerId = existing.CustomerId,
            AssignedToUserId = existing.AssignedToUserId,
            WorkOrderNumber = existing.WorkOrderNumber,
            CustomerName = existing.CustomerName,
            Address = existing.Address,
            Street1 = existing.Street1,
            City = existing.City,
            Latitude = existing.Latitude,
            Longitude = existing.Longitude,
            Status = existing.Status,
            Technician = existing.Technician,
            GateCode = existing.GateCode,
            AnimalsPresent = existing.AnimalsPresent,
            ServiceDetails = existing.ServiceDetails,
            DateSubmitted = existing.DateSubmitted,
            ScheduledDate = scheduledDate,
            ScheduledOrder = scheduledOrder,
            ServiceStartupDate = existing.ServiceStartupDate,
            ServiceContactName = existing.ServiceContactName,
            ServiceContactPhone = existing.ServiceContactPhone,
            BuilderCompanyName = existing.BuilderCompanyName,
            BuilderContactName = existing.BuilderContactName,
            BuilderContactPhone = existing.BuilderContactPhone,
            BuilderEmail = existing.BuilderEmail,
            CompletedBy = existing.CompletedBy,
            CompletedOn = existing.CompletedOn,
            HasPendingUpload = existing.HasPendingUpload
        };

    private static string DetailHref(WorkOrderSummary workOrder) =>
        workOrder.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase)
        || workOrder.Status.Equals("New", StringComparison.OrdinalIgnoreCase)
            ? $"/service-requests/{workOrder.Id}"
            : workOrder.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase)
                ? $"/work-orders/history/{workOrder.Id}"
                : $"/work-orders/active/{workOrder.Id}";

    private static string DayPillClass(DateOnly day) =>
        day.DayOfWeek switch
        {
            DayOfWeek.Monday => "cb-day-mon",
            DayOfWeek.Tuesday => "cb-day-tue",
            DayOfWeek.Wednesday => "cb-day-wed",
            DayOfWeek.Thursday => "cb-day-thu",
            DayOfWeek.Friday => "cb-day-fri",
            _ => string.Empty
        };

    private static string DayBadge(DateOnly day) =>
        day.DayOfWeek switch
        {
            DayOfWeek.Monday => "M",
            DayOfWeek.Tuesday => "T",
            DayOfWeek.Wednesday => "W",
            DayOfWeek.Thursday => "Th",
            DayOfWeek.Friday => "F",
            _ => string.Empty
        };

    private static string FirstLine(string value) =>
        string.IsNullOrWhiteSpace(value)
            ? "Unknown Address"
            : value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? value;

    private RenderFragment RenderScheduleCard(WorkOrderSummary workOrder) => builder =>
    {
        builder.OpenElement(0, "article");
        builder.AddAttribute(1, "class", $"sch-item schedule-stop-card {(workOrder.Id == _armedWorkOrderId ? "sch-item-armed" : string.Empty)}");
        builder.AddAttribute(2, "role", "button");
        builder.AddAttribute(3, "tabindex", "0");
        builder.AddAttribute(4, "onclick", EventCallback.Factory.Create(this, () => ArmWorkOrder(workOrder.Id)));

        builder.OpenElement(5, "div");
        builder.AddAttribute(6, "class", "sch-item-row");

        builder.OpenElement(7, "div");
        builder.AddAttribute(8, "class", "sch-item-title");
        builder.OpenElement(9, "span");
        builder.AddAttribute(10, "class", "sch-item-street");
        builder.AddContent(11, StreetOnly(workOrder));
        builder.CloseElement();
        builder.OpenElement(12, "span");
        builder.AddAttribute(13, "class", "sch-item-desc");
        builder.AddContent(14, ProblemText(workOrder));
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(15, "a");
        builder.AddAttribute(16, "class", "icon-action ghost-action sch-item-open");
        builder.AddAttribute(17, "href", DetailHref(workOrder));
        builder.AddAttribute(18, "title", "Open work order");
        builder.AddAttribute(19, "aria-label", "Open work order");
        builder.AddAttribute(20, "onclick", "event.stopPropagation();");
        builder.OpenElement(21, "span");
        builder.AddAttribute(22, "class", "schedule-open-glyph");
        builder.AddContent(23, "\u2197");
        builder.CloseElement();
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment RenderScheduleRouteCard(WorkOrderSummary workOrder) => builder =>
    {
        var order = SelectedDayStops.ToList().FindIndex(x => x.Id == workOrder.Id);
        var isFirst = order <= 0;
        var isLast = order == SelectedDayStops.Count - 1;

        builder.OpenElement(0, "article");
        builder.AddAttribute(1, "class", $"sch-item schedule-stop-card sch-route-card {(workOrder.Id == _armedWorkOrderId ? "sch-item-armed" : string.Empty)}");
        builder.AddAttribute(2, "role", "button");
        builder.AddAttribute(3, "tabindex", "0");
        builder.AddAttribute(4, "onclick", EventCallback.Factory.Create(this, () => ArmWorkOrder(workOrder.Id)));

        builder.OpenElement(5, "div");
        builder.AddAttribute(6, "class", "sch-route-card-main");

        builder.OpenElement(7, "div");
        builder.AddAttribute(8, "class", "sch-route-order");
        builder.AddContent(9, order + 1);
        builder.CloseElement();

        builder.OpenElement(10, "div");
        builder.AddAttribute(11, "class", "sch-route-copy");
        builder.OpenElement(12, "span");
        builder.AddAttribute(13, "class", "sch-item-street");
        builder.AddContent(14, StreetOnly(workOrder));
        builder.CloseElement();
        builder.OpenElement(15, "span");
        builder.AddAttribute(16, "class", "sch-item-desc");
        builder.AddContent(17, ProblemText(workOrder));
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(18, "div");
        builder.AddAttribute(19, "class", "sch-route-actions");

        builder.OpenElement(20, "button");
        builder.AddAttribute(21, "class", "icon-action ghost-action sch-route-shift");
        builder.AddAttribute(22, "type", "button");
        builder.AddAttribute(23, "disabled", isFirst);
        builder.AddAttribute(24, "title", "Move up");
        builder.AddAttribute(25, "aria-label", "Move up");
        builder.AddEventStopPropagationAttribute(26, "onclick", true);
        builder.AddAttribute(27, "onclick", EventCallback.Factory.Create(this, () => MoveRouteStopAsync(workOrder.Id, -1)));
        builder.AddContent(27, "\u2191");
        builder.CloseElement();

        builder.OpenElement(28, "button");
        builder.AddAttribute(29, "class", "icon-action ghost-action sch-route-shift");
        builder.AddAttribute(30, "type", "button");
        builder.AddAttribute(31, "disabled", isLast);
        builder.AddAttribute(32, "title", "Move down");
        builder.AddAttribute(33, "aria-label", "Move down");
        builder.AddEventStopPropagationAttribute(34, "onclick", true);
        builder.AddAttribute(35, "onclick", EventCallback.Factory.Create(this, () => MoveRouteStopAsync(workOrder.Id, 1)));
        builder.AddContent(35, "\u2193");
        builder.CloseElement();

        builder.OpenElement(36, "a");
        builder.AddAttribute(37, "class", "icon-action ghost-action sch-item-open");
        builder.AddAttribute(38, "href", DetailHref(workOrder));
        builder.AddAttribute(39, "title", "Open work order");
        builder.AddAttribute(40, "aria-label", "Open work order");
        builder.AddAttribute(41, "onclick", "event.stopPropagation();");
        builder.OpenElement(42, "span");
        builder.AddAttribute(43, "class", "schedule-open-glyph");
        builder.AddContent(44, "\u2197");
        builder.CloseElement();
        builder.CloseElement();

        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

