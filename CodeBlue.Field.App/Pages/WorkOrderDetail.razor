    private static RenderFragment InfoRow(string label, string? value) => @<div class="field-info-row"><span>@label</span><strong>@BlankDash(value)</strong></div>;
    private static RenderFragment InfoLinkRow(string label, string? value, string href) => @<div class="field-info-row"><span>@label</span><a href="@href">@BlankDash(value)</a></div>;
    private static string StreetOnly(WorkOrderSummary workOrder) =>
        !string.IsNullOrWhiteSpace(workOrder.Street1)
            ? workOrder.Street1
            : string.IsNullOrWhiteSpace(workOrder.Address)
                ? workOrder.CustomerName
                : workOrder.Address.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? workOrder.Address;
    private static string StreetOnly(CustomerSummary customer) => string.IsNullOrWhiteSpace(customer.Street1) ? customer.Address : customer.Street1;
    private static string ProblemText(WorkOrderSummary workOrder) => string.IsNullOrWhiteSpace(workOrder.ServiceDetails) ? "No service details recorded." : workOrder.ServiceDetails;
    private static string ClaimDescription(ClaimSummary claim)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(claim.ComponentCode)) parts.Add(claim.ComponentCode);
        if (!string.IsNullOrWhiteSpace(claim.ModelNumber)) parts.Add(claim.ModelNumber);
        return parts.Count == 0 ? "Claim" : string.Join(" • ", parts);
    }
    private static string TechnicianOrFallback(WorkOrderSummary workOrder) => string.IsNullOrWhiteSpace(workOrder.Technician) ? "Unassigned" : workOrder.Technician;
    private static string BlankDash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;
    private static string DisplayDate(DateOnly? date) => date?.ToString("MM/dd/yyyy") ?? "—";
    private static string MapsLink(WorkOrderSummary workOrder) => $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(workOrder.Address)}";
    private static string TelLink(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return "#";
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits) ? "#" : $"tel:{digits}";
    }
    private static string ClaimFileUrl(Uri? baseAddress, string storageKey) => ClaimImageUtil.ResolveImageUrl(baseAddress, storageKey);
}
